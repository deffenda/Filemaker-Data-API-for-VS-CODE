  "publisher": "deffenda",
  "license": "MIT",
  "icon": "docs/marketplace/icon.png",
  "galleryBanner": {
    "color": "#081726",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/deffenda/filemaker-data-api-for-vs-code.git"
  },
  "homepage": "https://github.com/deffenda/filemaker-data-api-for-vs-code",
